# Database
# Pooled endpoint (has -pooler in the host) — used by the app at runtime.
DATABASE_URL=
# Direct/unpooled endpoint (same URL, remove -pooler from the host) — used ONLY
# by `prisma migrate`/`prisma db push`. Pooled connections break migration replay.
DIRECT_URL=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Anthropic Claude API (leave empty for now, filled in Phase 3)
ANTHROPIC_API_KEY=

# Self-hosted Piston (code execution sandbox). See "Code execution" section
# in README.md for setup instructions.
PISTON_URL=http://localhost:2000/api/v2

# Secret used to derive per-problem anti-cheat canary tokens
# (src/lib/anticheat.ts). Falls back to a fixed dev value if unset, but set
# a real random value outside local dev so tokens aren't guessable.
ANTICHEAT_SECRET=

# Google Gemini API (free tier). Get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Comma-separated emails granted full admin permissions by `npm run admin:bootstrap`.
# The listed users must have signed in at least once (the script never creates users).
ADMIN_EMAILS=""

# Transactional email (password reset) via Gmail SMTP.
# SMTP_USER  = your Gmail address (e.g. codeforge26@gmail.com)
# SMTP_PASS  = a Google App Password (16 chars) -- requires 2-Step Verification.
#              Create at https://myaccount.google.com/apppasswords
# EMAIL_FROM = optional display sender; defaults to "CodeForge <SMTP_USER>".
# In development, if these are unset, reset links are logged to the server
# console instead of emailed.
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""
