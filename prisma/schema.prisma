generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Granular admin capabilities. Users hold zero or more of these; any non-empty
// set makes them staff. Checked server-side on every admin route/action (the
// middleware gate is only defense-in-depth). See src/lib/authz.ts.
enum Permission {
  VIEW_ADMIN        // can open the admin panel at all
  VIEW_USERS        // list/inspect users
  VIEW_PII          // see emails and other identifying fields
  VIEW_SUBMISSIONS  // inspect any user's submissions
  VIEW_ANTICHEAT    // access the anti-cheat review queue
  VIEW_AUDIT        // read the audit log
  BAN_USER          // ban / unban users
  REVOKE_SUBMISSION // revoke / restore submissions
  WARN_USER         // issue warnings
  MANAGE_ADMINS     // grant/revoke permissions on other users
  MANAGE_CONTESTS   // create / cancel contests
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime? @db.Timestamptz(3)
  image         String?
  // Public profile fields, editable from the profile page (all optional).
  bio           String?   @db.Text
  location      String?
  githubHandle  String?
  website       String?
  // --- Admin / RBAC ---
  // Granular capabilities. Empty for normal users; any entry marks staff.
  permissions   Permission[] @default([])
  // --- Moderation state (soft + reversible; nothing is hard-deleted) ---
  banned        Boolean   @default(false)
  bannedAt      DateTime? @db.Timestamptz(3)
  // When the ban lifts. NULL while banned means a permanent ban; a past value
  // means the ban has expired (enforcement treats it as inactive). Cleared on
  // unban. See src/lib/ban.ts for the single source of truth on "is this ban
  // currently active".
  bannedUntil   DateTime? @db.Timestamptz(3)
  bannedReason  String?   @db.Text
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)
  accounts      Account[]
  sessions      Session[]
  submissions   Submission[]
  progress      UserProgress[]
  taskClaims    TaskClaim[]
  badges        UserBadge[]
  // Warnings received, and warnings/audit entries this user authored as staff.
  warnings        Warning[]  @relation("WarningTarget")
  warningsIssued  Warning[]  @relation("WarningIssuer")
  auditLogs       AuditLog[] @relation("AuditActor")
  contestsCreated Contest[]  @relation("ContestCreator")
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

// A claimed daily/weekly task. `periodKey` scopes the claim to its window
// (a UTC day "YYYY-MM-DD" for dailies, an ISO week "YYYY-Www" for weeklies),
// so the same task can be earned again next period. XP is snapshotted at claim
// time and summed into the user's total, on top of derived solve XP.
model TaskClaim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskKey   String
  periodKey String
  xp        Int
  claimedAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([userId, taskKey, periodKey])
  @@index([userId])
  @@map("task_claims")
}

// A badge, persisted once unlocked so it stays earned even if the underlying
// condition later lapses (e.g. a streak breaks). Awarded from the judge flow.
model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey String
  earnedAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([userId, badgeKey])
  @@index([userId])
  @@map("user_badges")
}

// A warning issued to a user by staff. Soft record; kept for history even after
// acknowledgement. Every issuance also writes an AuditLog row.
model Warning {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation("WarningTarget", fields: [userId], references: [id], onDelete: Cascade)
  issuedByUserId String
  issuedBy       User      @relation("WarningIssuer", fields: [issuedByUserId], references: [id], onDelete: Cascade)
  reason         String    @db.Text
  acknowledgedAt DateTime? @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@map("warnings")
}

// Append-only audit trail for every privileged state change (ban, revoke, warn,
// permission grant). Never updated or deleted from app code.
enum AuditAction {
  BAN_USER
  UNBAN_USER
  REVOKE_SUBMISSION
  RESTORE_SUBMISSION
  WARN_USER
  GRANT_PERMISSIONS
  REVOKE_PERMISSIONS
  CREATE_CONTEST
  CANCEL_CONTEST
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String
  actor       User        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  action      AuditAction
  targetType  String      // "user" | "submission"
  targetId    String
  reason      String?     @db.Text
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime    @default(now()) @db.Timestamptz(3)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// A single-use password-reset token. We store only the SHA-256 *hash* of the
// token, never the token itself, so a database leak cannot be used to reset
// passwords. The raw token lives only in the emailed link. Expires quickly and
// is deleted (or marked used) on redemption.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime @db.Timestamptz(3)
  usedAt    DateTime? @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Topic {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  order       Int       @default(0)
  problems    Problem[]
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)

  @@map("topics")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  statement     String         @db.Text
  constraints   String?        @db.Text
  difficulty    Difficulty     @default(EASY)
  order         Int            @default(0)
  starterCode   Json?
  // When true, the statement panel blocks/poisons copy attempts (see
  // src/lib/anticheat.ts). Defaults on; curators can turn it off per-problem.
  copyProtected Boolean        @default(true)
  topicId       String
  topic         Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  testCases     TestCase[]
  submissions   Submission[]
  progress      UserProgress[]
  contestProblems ContestProblem[]
  createdAt     DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(3)

  @@map("problems")
}

model TestCase {
  id        String  @id @default(cuid())
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input     String  @db.Text
  expected  String  @db.Text
  isSample  Boolean @default(false)
  order     Int     @default(0)

  @@map("test_cases")
}

enum Verdict {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  COMPILE_ERROR
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code        String   @db.Text
  language    String
  verdict     Verdict  @default(PENDING)
  testResults Json?
  runtimeMs   Int?
  // Heuristic anti-cheat signal: true if the submitted code contains this
  // problem's canary token (see src/lib/anticheat.ts). Not enforced/blocked,
  // just recorded for later review -- a detect-and-discourage signal, not proof.
  suspectedAiPasted Boolean  @default(false)
  // --- Moderation (soft): revoked submissions are hidden from public views
  // (profile, leaderboards, problem history) but never deleted, and can be
  // restored. Set only from the admin panel via an audited action.
  revoked       Boolean   @default(false)
  revokedAt     DateTime? @db.Timestamptz(3)
  revokedReason String?   @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  @@index([suspectedAiPasted])
  @@map("submissions")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  SOLVED
}

model UserProgress {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId     String
  problem       Problem        @relation(fields: [problemId], references: [id], onDelete: Cascade)
  status        ProgressStatus @default(NOT_STARTED)
  attempts      Int            @default(0)
  bestVerdict   Verdict?
  lastAttemptAt DateTime? @db.Timestamptz(3)
  solvedAt      DateTime? @db.Timestamptz(3)

  @@unique([userId, problemId])
  @@map("user_progress")
}

// A weekly rated round. An admin chooses only the difficulty; the system
// auto-selects 3 problems of that difficulty from the problem set and schedules
// the round for the next free Sunday 22:00 local slot, running for one hour.
// Phase 1 stores the definition + schedule; solving/leaderboard/XP land in a
// later phase (see the contests feature notes).
model Contest {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  // All three problems share this difficulty (all-easy / all-medium / all-hard).
  difficulty  Difficulty
  startsAt    DateTime @db.Timestamptz(3)
  endsAt      DateTime @db.Timestamptz(3)
  // Who created it (staff). Kept for the audit trail / attribution.
  createdByUserId String?
  createdBy   User?            @relation("ContestCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  problems    ContestProblem[]
  createdAt   DateTime         @default(now()) @db.Timestamptz(3)

  @@index([startsAt])
  @@map("contests")
}

// Join row pinning a specific problem into a contest at a fixed position (1..3).
model ContestProblem {
  id        String  @id @default(cuid())
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  order     Int     @default(0)

  @@unique([contestId, problemId])
  @@index([contestId])
  @@map("contest_problems")
}
