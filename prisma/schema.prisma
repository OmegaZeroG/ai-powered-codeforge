generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  // Public profile fields, editable from the profile page (all optional).
  bio           String?   @db.Text
  location      String?
  githubHandle  String?
  website       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  submissions   Submission[]
  progress      UserProgress[]
  taskClaims    TaskClaim[]
  badges        UserBadge[]

  @@map("users")
}

// A claimed daily/weekly task. `periodKey` scopes the claim to its window
// (a UTC day "YYYY-MM-DD" for dailies, an ISO week "YYYY-Www" for weeklies),
// so the same task can be earned again next period. XP is snapshotted at claim
// time and summed into the user's total, on top of derived solve XP.
model TaskClaim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskKey   String
  periodKey String
  xp        Int
  claimedAt DateTime @default(now())

  @@unique([userId, taskKey, periodKey])
  @@index([userId])
  @@map("task_claims")
}

// A badge, persisted once unlocked so it stays earned even if the underlying
// condition later lapses (e.g. a streak breaks). Awarded from the judge flow.
model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeKey String
  earnedAt DateTime @default(now())

  @@unique([userId, badgeKey])
  @@index([userId])
  @@map("user_badges")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Topic {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  order       Int       @default(0)
  problems    Problem[]
  createdAt   DateTime  @default(now())

  @@map("topics")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  statement     String         @db.Text
  constraints   String?        @db.Text
  difficulty    Difficulty     @default(EASY)
  order         Int            @default(0)
  starterCode   Json?
  // When true, the statement panel blocks/poisons copy attempts (see
  // src/lib/anticheat.ts). Defaults on; curators can turn it off per-problem.
  copyProtected Boolean        @default(true)
  topicId       String
  topic         Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  testCases     TestCase[]
  submissions   Submission[]
  progress      UserProgress[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("problems")
}

model TestCase {
  id        String  @id @default(cuid())
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input     String  @db.Text
  expected  String  @db.Text
  isSample  Boolean @default(false)
  order     Int     @default(0)

  @@map("test_cases")
}

enum Verdict {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  COMPILE_ERROR
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  code        String   @db.Text
  language    String
  verdict     Verdict  @default(PENDING)
  testResults Json?
  runtimeMs   Int?
  // Heuristic anti-cheat signal: true if the submitted code contains this
  // problem's canary token (see src/lib/anticheat.ts). Not enforced/blocked,
  // just recorded for later review -- a detect-and-discourage signal, not proof.
  suspectedAiPasted Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("submissions")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  SOLVED
}

model UserProgress {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId     String
  problem       Problem        @relation(fields: [problemId], references: [id], onDelete: Cascade)
  status        ProgressStatus @default(NOT_STARTED)
  attempts      Int            @default(0)
  bestVerdict   Verdict?
  lastAttemptAt DateTime?
  solvedAt      DateTime?

  @@unique([userId, problemId])
  @@map("user_progress")
}